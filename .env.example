# Copy to `.env` and fill in from Firebase Console → Project settings → Your apps → SDK setup.
# Vite only exposes variables prefixed with VITE_ to client code.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if you add Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=

# Optional — POST JSON endpoints for transactional e-mail (e.g. your own API / serverless).
# VITE_REGISTRATION_EMAIL_ENDPOINT=
# VITE_CONTACT_FORM_EMAIL_ENDPOINT=

# Zoho Creator — portal login URLs (used on /login).
# VITE_ZOHO_FREELANCER_PORTAL_URL=
# VITE_ZOHO_COMPANY_PORTAL_URL=

# SEO — canonieke productie-URL (geen trailing slash); gebruikt in OG, JSON-LD, sitemap/robots build.
# VITE_SITE_URL=https://www.voorbeeld.nl
# Optioneel: vaste social preview-afbeelding (https-URL of pad vanaf site-root).
# VITE_OG_IMAGE_URL=
# Optioneel: Twitter/X @handle inclusief @ voor twitter:site
# VITE_TWITTER_SITE=@hb_servicegroup
